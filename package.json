{
  "name": "@axora/mvp",
  "version": "0.1.0",
  "description": "AXORA - Multi-Agent Coding System",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "proto:gen": "cd proto && buf generate",
    "dev:daemon": "cargo run -p axora-daemon",
    "dev:desktop": "pnpm --filter @axora/desktop dev"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.14.0",
  "dependencies": {
    "next-themes": "^0.4.6"
  }
}
