{
  "name": "@openakta/mvp",
  "version": "0.1.0",
  "description": "OPENAKTA - Multi-Agent Coding System",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=!@openakta/mvp",
    "build": "turbo run build --filter=!@openakta/mvp",
    "test": "turbo run test --filter=!@openakta/mvp",
    "lint": "turbo run lint --filter=!@openakta/mvp",
    "format": "turbo run format --filter=!@openakta/mvp",
    "typecheck": "turbo run typecheck --filter=!@openakta/mvp",
    "clean": "turbo run clean --filter=!@openakta/mvp && rm -rf node_modules",
    "proto:gen": "cd proto && buf generate",
    "proto:lint": "buf lint",
    "proto:breaking": "buf breaking --against '.git#branch=main,subdir=proto'",
    "dev:daemon": "cargo run -p openakta-daemon",
    "dev:desktop": "pnpm --filter @openakta/desktop dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.39.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.14.0",
  "dependencies": {
    "next-themes": "^0.4.6"
  }
}
