{
  "name": "@axora/mvp",
  "version": "0.1.0",
  "description": "AXORA - Multi-Agent Coding System",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=!@axora/mvp",
    "build": "turbo run build --filter=!@axora/mvp",
    "test": "turbo run test --filter=!@axora/mvp",
    "lint": "turbo run lint --filter=!@axora/mvp",
    "format": "turbo run format --filter=!@axora/mvp",
    "typecheck": "turbo run typecheck --filter=!@axora/mvp",
    "clean": "turbo run clean --filter=!@axora/mvp && rm -rf node_modules",
    "proto:gen": "cd proto && buf generate",
    "dev:daemon": "cargo run -p axora-daemon",
    "dev:desktop": "pnpm --filter @axora/desktop dev"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "turbo": "^2.0.0",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.14.0",
  "dependencies": {
    "next-themes": "^0.4.6"
  }
}
