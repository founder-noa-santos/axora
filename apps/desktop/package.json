    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "4",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.0",
