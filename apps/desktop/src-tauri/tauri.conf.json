{
  "$schema": "https://schema.tauri.app/tauri.conf.json",
  "productName": "AXORA",
  "version": "0.1.0",
  "identifier": "dev.axora.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "AXORA - Multi-Agent Coding System",
        "width": 1200
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"],
    "category": "DeveloperTool"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
